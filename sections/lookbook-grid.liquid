{{ 'component-lookbook.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<div class="lookbook color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <ul class="lookbook__grid lookbook__grid--{{ section.settings.columns_desktop }}-col" role="list">
      {%- for product in collection.products -%}
        <li class="lookbook__item">
          <button
            class="lookbook__trigger"
            aria-label="{{ product.title | escape }}"
            data-lookbook-product="{{ product.id }}"
          >
            {%- if product.featured_media -%}
              {{
                product.featured_media
                | image_url: width: 800
                | image_tag:
                  class: 'lookbook__img',
                  loading: 'lazy',
                  widths: '400, 600, 800',
                  sizes: '(min-width: 990px) calc(100vw / ' | append: section.settings.columns_desktop | append: '), (min-width: 750px) 50vw, 100vw',
                  alt: product.title
              }}
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'lookbook__img placeholder-svg' }}
            {%- endif -%}
            <div class="lookbook__overlay" aria-hidden="true">
              <span class="lookbook__overlay-icon">+</span>
            </div>
          </button>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

<div class="lookbook-modal" id="LookbookModal" role="dialog" aria-modal="true" aria-label="{{ 'accessibility.close' | t }}" hidden>
  <div class="lookbook-modal__backdrop"></div>
  <div class="lookbook-modal__dialog">
    <button class="lookbook-modal__close" aria-label="{{ 'accessibility.close' | t }}">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M1 1l16 16M17 1L1 17"/>
      </svg>
    </button>
    <div class="lookbook-modal__media"></div>
    <div class="lookbook-modal__info">
      <h2 class="lookbook-modal__title"></h2>
      <div class="lookbook-modal__price"></div>
      <a class="lookbook-modal__link button" href="#">
        {{ 'products.product.view_full_details' | t }}
      </a>
    </div>
  </div>
</div>

<script>
(function(){
  var modal = document.getElementById('LookbookModal');
  if (!modal) return;
  var backdrop = modal.querySelector('.lookbook-modal__backdrop');
  var closeBtn = modal.querySelector('.lookbook-modal__close');
  var mediaEl = modal.querySelector('.lookbook-modal__media');
  var titleEl = modal.querySelector('.lookbook-modal__title');
  var priceEl = modal.querySelector('.lookbook-modal__price');
  var linkEl  = modal.querySelector('.lookbook-modal__link');

  var products = {};
  {%- for product in collection.products -%}
  products[{{ product.id | json }}] = {
    title: {{ product.title | json }},
    price: {{ product.price | money | json }},
    url: {{ product.url | json }},
    image: {{ product.featured_media | image_url: width: 800 | json }}
  };
  {%- endfor -%}

  function openModal(id) {
    var p = products[id];
    if (!p) return;
    mediaEl.innerHTML = '<img src="' + p.image + '" alt="' + p.title + '" style="width:100%;height:100%;object-fit:cover">';
    titleEl.textContent = p.title;
    priceEl.textContent = p.price;
    linkEl.href = p.url;
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('[data-lookbook-product]').forEach(function(btn) {
    btn.addEventListener('click', function() { openModal(this.dataset.lookbookProduct); });
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  modal.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
})();
</script>

{% schema %}
{
  "name": "Lookbook Grid",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2, "max": 4, "step": 1,
      "label": "Columns (desktop)",
      "default": 3
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "options": [
        { "value": "scheme-1", "label": "t:sections.all.colors.scheme_1_label" },
        { "value": "scheme-2", "label": "t:sections.all.colors.scheme_2_label" },
        { "value": "scheme-3", "label": "t:sections.all.colors.scheme_3_label" }
      ],
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 60
    }
  ],
  "presets": [
    { "name": "Lookbook Grid" }
  ]
}
{% endschema %}
