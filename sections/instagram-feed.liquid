{%- style -%}
  .instagram-feed {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .instagram-feed__heading {
    text-align: center;
    margin-bottom: 2rem;
    letter-spacing: 0.1em;
  }

  .instagram-feed__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .instagram-feed__item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    display: block;
    text-decoration: none;
  }

  .instagram-feed__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .instagram-feed__item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    transition: background 0.3s ease;
    pointer-events: none;
  }

  .instagram-feed__item:hover::after {
    background: rgba(0, 0, 0, 0.18);
  }

  .instagram-feed__item:hover img {
    transform: scale(1.04);
  }

  .instagram-feed__placeholder {
    width: 100%;
    height: 100%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .instagram-feed__placeholder svg {
    width: 40px;
    height: 40px;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .instagram-feed__grid {
      gap: 3px;
    }
  }
{%- endstyle -%}

<div class="instagram-feed">
  {%- if section.settings.heading != blank -%}
    <h2 class="instagram-feed__heading h3">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="instagram-feed__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        if block.settings.product_handle != blank
          assign item_href = '/products/' | append: block.settings.product_handle | append: '?utm_source=instagram'
        elsif section.settings.ig_url != blank
          assign item_href = section.settings.ig_url
        else
          assign item_href = '#'
        endif

        if block.settings.product_handle != blank
          assign item_target = '_self'
        else
          assign item_target = '_blank'
        endif
      -%}
      <a
        href="{{ item_href }}"
        class="instagram-feed__item"
        target="{{ item_target }}"
        rel="{% if item_target == '_blank' %}noopener noreferrer{% endif %}"
        aria-label="{{ block.settings.alt_text | default: section.settings.heading }}"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          {{
            block.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 800',
              sizes: '(min-width: 750px) 33vw, 33vw',
              alt: block.settings.alt_text | escape
          }}
        {%- else -%}
          <div class="instagram-feed__placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </div>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Instagram Feed",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FROM OUR INSTAGRAM"
    },
    {
      "type": "url",
      "id": "ig_url",
      "label": "Instagram profile URL"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text"
        },
        {
          "type": "text",
          "id": "product_handle",
          "label": "Link to product handle (leave blank for IG link)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}
