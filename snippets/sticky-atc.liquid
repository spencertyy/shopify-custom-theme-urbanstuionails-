<style>
  .sticky-atc {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #fff;
    border-top: 1px solid rgba(var(--color-foreground), 0.12);
    padding: 1.2rem calc(4rem / var(--font-body-scale));
    display: flex;
    align-items: center;
    gap: 1.2rem;
    transform: translateY(100%);
    transition: transform 0.28s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 -4px 24px rgba(0,0,0,.08);
  }
  .sticky-atc.is-visible { transform: translateY(0); }
  .sticky-atc__thumb {
    width: 4.8rem;
    height: 4.8rem;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid rgba(var(--color-foreground), 0.08);
  }
  .sticky-atc__info { flex: 1; min-width: 0; }
  .sticky-atc__title {
    font-size: 1.3rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sticky-atc__price { font-size: 1.3rem; color: rgba(var(--color-foreground), 0.75); }
  .sticky-atc__btn {
    flex-shrink: 0;
    padding: 1rem 2rem;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: none;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: .04em;
    cursor: pointer;
    white-space: nowrap;
  }
  .sticky-atc__btn:hover { opacity: .88; }
  @media screen and (min-width: 990px) { .sticky-atc { display: none; } }
</style>

<div class="sticky-atc" id="StickyAtc-{{ product.id }}" aria-hidden="true">
  {%- if product.featured_media -%}
    {{
      product.featured_media
      | image_url: width: 120
      | image_tag: class: 'sticky-atc__thumb', loading: 'lazy', alt: product.title
    }}
  {%- endif -%}
  <div class="sticky-atc__info">
    <div class="sticky-atc__title">{{ product.title }}</div>
    <div class="sticky-atc__price">
      {{- product.selected_or_first_available_variant.price | money -}}
    </div>
  </div>
  <button
    class="sticky-atc__btn"
    onclick="document.getElementById('ProductSubmitButton-{{ section.id }}')?.click()"
    aria-label="{{ 'products.product.add_to_cart' | t }}"
  >
    {{ 'products.product.add_to_cart' | t }}
  </button>
</div>

<script>
(function(){
  var bar = document.getElementById('StickyAtc-{{ product.id }}');
  if (!bar) return;
  var mainBtn = document.getElementById('ProductSubmitButton-{{ section.id }}');
  if (!mainBtn) return;
  var observer = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      var show = !e.isIntersecting;
      bar.classList.toggle('is-visible', show);
      bar.setAttribute('aria-hidden', !show);
    });
  }, { rootMargin: '0px 0px -80px 0px' });
  observer.observe(mainBtn);
})();
</script>
